    print(mac_rakip1[mac_index] + " " + str(mac_rakip1_gol[mac_index]) + " - " + str(mac_rakip2_gol[mac_index]) + " " + mac_rakip2[mac_index])


# ─── 1071 ──────────────────────────────────────────────
def mac_baslat():
    eslestirmeleri_goster()
    if not mac_rakip1:
        return
    try:
        mac_no = int(input("Hangi mac oynanacak (numara): ")) - 1
    except ValueError:
        print("Gecersiz giris.")
        return
    if mac_no < 0 or mac_no >= len(mac_rakip1):
        print("Gecersiz mac numarasi.")
        return

    mac_rakip1_gol[mac_no] = 0
    mac_rakip2_gol[mac_no] = 0
    print("tum seyirciler " + str(mac_no + 1) + ". mac derbisinin baslamasini bekliyor iyi seyirler")
    print(mac_rakip1[mac_no] + " vs " + mac_rakip2[mac_no])

    while True:
        print("")
        print("Gol atan taraf?")
        print("  1 - " + mac_rakip1[mac_no])
        print("  2 - " + mac_rakip2[mac_no])
        print("  3 - Mac bitti")
        secim = input("Secim: ")
        if secim == "1":
            skor_guncelle(mac_no, 1)
        elif secim == "2":
            skor_guncelle(mac_no, 2)
        elif secim == "3":
            mac_bitir(mac_no)
            break
        else:
            print("Gecersiz secim.")


# ─── mac_bitir ──────────────────────────────────────────────
def mac_bitir(mac_no):
    r1_gol = mac_rakip1_gol[mac_no]
    r2_gol = mac_rakip2_gol[mac_no]
    print("")
    print("=== Mac Bitti ===")
    print(mac_rakip1[mac_no] + " " + str(r1_gol) + " - " + str(r2_gol) + " " + mac_rakip2[mac_no])
    if r1_gol > r2_gol:
        print("Kazanan: " + mac_rakip1[mac_no])
        puan_tablosu_guncelle(mac_no, 1)
    elif r2_gol > r1_gol:
        print("Kazanan: " + mac_rakip2[mac_no])
        puan_tablosu_guncelle(mac_no, 2)
    else:
        print("Mac berabere bitti.")
        puan_tablosu_guncelle(mac_no, 0)


# ─── 1230 ──────────────────────────────────────────────
def puan_tablosu_guncelle(mac_no, mac_sonucu):
    # mac_sonucu: 0=berabere, 1=rakip1 kazandi, 2=rakip2 kazandi
    if mac_sonucu == 0:
        puan_listesi[mac_rakip1[mac_no]] = puan_listesi.get(mac_rakip1[mac_no], 0) + 1
        puan_listesi[mac_rakip2[mac_no]] = puan_listesi.get(mac_rakip2[mac_no], 0) + 1
    elif mac_sonucu == 1:
        puan_listesi[mac_rakip1[mac_no]] = puan_listesi.get(mac_rakip1[mac_no], 0) + 3
    elif mac_sonucu == 2:
        puan_listesi[mac_rakip2[mac_no]] = puan_listesi.get(mac_rakip2[mac_no], 0) + 3


