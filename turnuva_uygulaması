def eslestirmeleri_olustur():
    global mac_rakip1, mac_rakip2, mac_rakip1_gol, mac_rakip2_gol
    if len(oyuncu_listesi) < 2:
        print("En az 2 oyuncu gerekli.")
        return
    mac_rakip1 = []
    mac_rakip2 = []
    mac_rakip1_gol = []
    mac_rakip2_gol = []
    kullanilan = []
    oyuncular = oyuncu_listesi[:]
    random.shuffle(oyuncular)
    for i in range(0, len(oyuncular) - 1, 2):
        mac_rakip1.append(oyuncular[i])
        mac_rakip2.append(oyuncular[i + 1])
        mac_rakip1_gol.append(0)
        mac_rakip2_gol.append(0)
    print("Eslestirmeler olusturuldu.")


