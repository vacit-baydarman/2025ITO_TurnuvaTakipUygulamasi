# ─── 1206 ──────────────────────────────────────────────
def oyuncu_sil():
    oyuncu_listesi_goster()
    silinecek_oyuncu = input("Silinecek oyuncunun adi: ")
    if oyuncu_arama(silinecek_oyuncu) == -1:
        print("Boyle bir oyuncu bulunamadi.")
        return
    oyuncu_listesi.remove(silinecek_oyuncu)
    if silinecek_oyuncu in puan_listesi:
        del puan_listesi[silinecek_oyuncu]
    if silinecek_oyuncu in gol_listesi:
        del gol_listesi[silinecek_oyuncu]
    print(silinecek_oyuncu + " silindi.")


# ─── 1238 + 1071 ──────────────────────────────────────────────
def oyuncu_guncelle():
    oyuncu_listesi_goster()
    eski_oyuncu = input("Guncellenecek oyuncunun adi: ")
    oyuncu_sirasi = oyuncu_arama(eski_oyuncu)
    if oyuncu_sirasi == -1:
        print("Boyle bir oyuncu bulunamadi.")
        return
    yeni_isim = input("Yeni isim: ")
    oyuncu_listesi[oyuncu_sirasi] = yeni_isim
    if eski_oyuncu in puan_listesi:
        puan_listesi[yeni_isim] = puan_listesi.pop(eski_oyuncu)
    if eski_oyuncu in gol_listesi:
        gol_listesi[yeni_isim] = gol_listesi.pop(eski_oyuncu)
    print("oyuncunuzun yeni adi: " + yeni_isim)


