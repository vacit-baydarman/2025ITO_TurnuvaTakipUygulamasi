# ─── 1143 ────────────────────────────
def skor_guncelle(mac_index, atan_taraf):
    # atan_taraf: 1 = rakip1, 2 = rakip2
    if atan_taraf == 1:
        mac_rakip1_gol[mac_index] += 1
        gol_listesi[mac_rakip1[mac_index]] = gol_listesi.get(mac_rakip1[mac_index], 0) + 1
    elif atan_taraf == 2:
        mac_rakip2_gol[mac_index] += 1
        gol_listesi[mac_rakip2[mac_index]] = gol_listesi.get(mac_rakip2[mac_index], 0) + 1
    gol_animasyonu()
    skor_goster(mac_index)


