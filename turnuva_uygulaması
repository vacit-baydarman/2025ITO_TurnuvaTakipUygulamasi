# ─── 1018 ──────────────────────────────────────────────
def oyuncu_arama(oyuncu_ismi):
    for i, oyuncu in enumerate(oyuncu_listesi):
        if oyuncu_ismi == oyuncu:
            return i
    return -1


# ─── 1009 ──────────────────────────────────────────────
def oyuncu_ekle():
    print("Python Oyuncu Eklemeye hos geldiniz.")
    oyuncu_adi_soyadi = input("Eklenecek oyuncunun adi: ")
    if oyuncu_arama(oyuncu_adi_soyadi) != -1:
        print("Listede olan bir isim girdiniz.")
        return
    oyuncu_listesi.append(oyuncu_adi_soyadi)
    puan_listesi[oyuncu_adi_soyadi] = 0
    gol_listesi[oyuncu_adi_soyadi] = 0
    print(oyuncu_adi_soyadi + " eklendi.")


