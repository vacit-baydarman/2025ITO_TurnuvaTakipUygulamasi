# ─── 1240 + 1115 ──────────────────────────────────────────────
def turnuva_ozeti():
    print("╔═══════════✦❖✦═══════════╗")
    print("   ✦ ─── Turnuva Ozeti ─── ✦")
    if not mac_rakip1:
        print("   Henuz mac oynanmadi.")
    else:
        for i in range(len(mac_rakip1)):
            r1 = mac_rakip1_gol[i]
            r2 = mac_rakip2_gol[i]
            sonuc = mac_rakip1[i] + " " + str(r1) + " - " + str(r2) + " " + mac_rakip2[i]
            if r1 > r2:
                sonuc += "  =>  " + mac_rakip1[i] + " kazandi"
            elif r2 > r1:
                sonuc += "  =>  " + mac_rakip2[i] + " kazandi"
            else:
                sonuc += "  =>  berabere"
            print("   " + sonuc)
    print("╚═══════════✦❖✦═══════════╝")
    puan_tablosu_goster()
    en_iyi_golcu()


